#!/usr/bin/env bash

declare FOLLOW_LOCATION # HTTP redirect follow location
declare GAME_ID
declare GAME_DIR # directory for game data
PLAYERS=("aang" "katara" "toph" "zuko" "iroh")
GAME_NAME="mock-game"
PORT=7777
BASE_URL="http://localhost:$PORT"

# echos a cookie location given a player name
mkdir_game() {
	local game_id="$1"
	GAME_DIR="/tmp/rulette/$game_id"
	mkdir -p "$GAME_DIR" || return 1
}

cookie_file() {
	local player="$1"
	echo "$GAME_DIR/${player}.cookie"
}

request() {
	local method="$1"
	local url="${BASE_URL}${2}"
	local opts="$3"
	
	echo "  ${method} ${url} ${opts}"
	response=$(eval curl -si -X "${method}" "${url}" ${opts} -w "%{http_code}")
	
	http_code="${response: -3}"
	content="${response::-3}"
	location=$(echo "$content" | grep -i '^Location:' | awk '{print $2}' | tr -d '\r\n')

	printf "  %s" "$http_code"
	if [ "$http_code" -eq 303	 ]; then
		FOLLOW_LOCATION="$location"
		printf " --> %s\n" "${FOLLOW_LOCATION}"
		return 0
	fi
	printf "\n"
	if [ "$http_code" -ne 200 ]; then
		echo "  error"
		echo "${content}"
		return 1
	fi
	return 0
}

request_with_retry () {
	local retries=5
	local delay=1
	local count=0
	while ! request "$@"; do
		count=$((count + 1))
		if [ $count -ge $retries ]; then
			return 1
		fi
		echo "  retrying in ${delay}s ..."
		sleep $delay
	done
}


# START UP NEW GAME
echo "first visit"
request_with_retry "GET" "/"

echo "create game"
request "POST" "/create" "-F gamename=${GAME_NAME}"
GAME_ID="$(echo "$FOLLOW_LOCATION" | sed -n 's|.*/\([^/]*\)/.*|\1|p')"
if [ -z "$GAME_ID" ]; then
	echo "error: not a game id: $GAME_ID"
	exit 1
fi
mkdir_game "$GAME_ID"


P1_NAME=${PLAYERS[0]}
P1_COOKIE="$(cookie_file "$P1_NAME")"
echo "create user $P1_NAME from $FOLLOW_LOCATION"
request "POST" "$FOLLOW_LOCATION" "-c $P1_COOKIE -F username=$P1_NAME"

echo "join game $GAME_ID as $P1_NAME"
request "GET" "/$GAME_ID" "-b $P1_COOKIE"

# fetches the debug endpoint on behalf of some player, and saves to state.json
fetch_state() {
	local player="$1"
	local dir="$GAME_DIR/state.json"
	chmod 766 "$dir" 2>/dev/null || true
	echo "  watch -n 1 ${dir}"
	while true; do
		curl -s "$BASE_URL/$GAME_ID/data/state" -b "$(cookie_file "$player")" -o "$dir.tmp"
		if ! jq < "$dir.tmp" > /dev/null 2>&1; then
			printf "\r  error: invalid json %s" "$(date +%T)"
			continue
		else
			mv "$dir.tmp" "$dir"
		fi
		printf "\r  ${dir} (updated %s)" "$(date +%T)"
		sleep 1
	done
}

echo "fetch game state"
fetch_state "$P1_NAME" &
pid=$!
trap "echo 'cleaning up' && kill $pid" EXIT

# for player in "${PLAYERS[@]:1}"; do
# 	echo "join game $FOLLOW_LOCATION as $player"
# 	request "GET" "$FOLLOW_LOCATION" "-F username=$player -c $(cookie_file $player)"
# done
sleep 120
