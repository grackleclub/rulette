#!/usr/bin/env bash

declare verbose
case "$1" in
  -v) verbose="-v" ;;
  --verbose) verbose="-v" ;;
  *) verbose="" ;;
esac

info () {
  if [ -n "$verbose" ]; then
    echo "info: $1"
  fi
}

error() {
  echo "error: $1" >&2
  exit 1
}

# require sqlc
if ! command -v sqlc >/dev/null 2>&1; then
  error "sqlc required"
fi

# update sqlc definitions
info "sqlc: updating..."
if ! ./bin/sqlc; then
  error "sqlc generation failed"
else
  info "sqlc: done"
fi
#
# run go tests
info "go: testing..."
if ! go test "$verbose" ./...; then
  error "go test failed"
else
  info "go: tests passed!"
fi

